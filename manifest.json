{
  "manifest_version": 3,
  "name": "LLM DOM Agent",
  "version": "1.0",
  "description": "Extracts webpage text, queries an external LLM API, and performs DOM interactions based on AI's structured response.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Trigger LLM Agent"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Alt+A"
      },
      "description": "Trigger LLM DOM Agent"
    },
    "stop_autopilot": {
      "suggested_key": {
        "default": "Alt+X",
        "mac": "Alt+X"
      },
      "description": "Stop AutoPilot Loop"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "llm-dom-interactor@example.com",
      "strict_min_version": "109.0"
    }
  }
}
